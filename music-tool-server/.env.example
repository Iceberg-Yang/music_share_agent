# ── 网易云（无需登录） ──────────────────────────
# 搜索/验证功能无需配置

# ── LLM（GuessChatGraph 需要）──────────────────
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# ── 数据库（PostgresSaver 需要）────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
