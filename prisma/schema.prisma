generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Room {
  id           String        @id @default(cuid())
  name         String
  inviteCode   String        @unique
  status       String        @default("waiting") // waiting | ready | drawing | submitted | completed | expired
  topicSource  String        @default("default")  // default | ai
  topics       String        // JSON array string
  chatMood     String?
  chatKeywords String?       // JSON array string
  aiSummary    String?
  aiTags       String?       // JSON array string
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  expiresAt    DateTime

  // V2 Agent 字段
  agentPhase               String?  // Agent 工作流当前阶段
  agentPersonalityProfiles String?  // JSON：双人性格档案
  agentRelationship        String?  // JSON：关系分析
  agentNextSong            String?  // JSON：下一首推荐
  agentExecutionLog        String?  // JSON：Agent 执行日志数组

  // V4 记忆系统字段
  userIdA      String?  // 创建者设备 ID
  userIdB      String?  // 加入者设备 ID
  pairId       String?  // SHA256(userIdA_userIdB)

  participants Participant[]
  entries      MusicEntry[]
  reactions    GameReaction[]
}

model Participant {
  id           String      @id @default(cuid())
  roomId       String
  nickname     String
  sessionToken String      @unique @default(cuid())
  drawnTopic   String?
  joinedAt     DateTime    @default(now())

  // V4 互猜字段
  guess        String?   // 猜测对方主题
  guessCorrect Boolean?  // 是否猜对

  room         Room        @relation(fields: [roomId], references: [id])
  entry        MusicEntry?
  reactions    GameReaction[]
}

model MusicEntry {
  id            String      @id @default(cuid())
  roomId        String
  participantId String      @unique
  topic         String
  songName      String
  artist        String
  musicUrl      String?
  reason        String?
  createdAt     DateTime    @default(now())

  room          Room        @relation(fields: [roomId], references: [id])
  participant   Participant @relation(fields: [participantId], references: [id])
}

// V4 新增：用户音乐记忆
model UserMemory {
  id          String   @id @default(cuid())
  userId      String   @unique

  gamesPlayed Int      @default(0)
  nickname    String?

  musicDNA    String?  // JSON: { styles, keywords, songs[] }
  usedTopics  String?  // JSON: string[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// V4 新增：双人关系记忆
model PairMemory {
  id             String   @id @default(cuid())
  pairId         String   @unique  // sorted(userIdA, userIdB) 拼接后 hash

  gamesPlayed    Int      @default(0)
  gameHistory    String?  // JSON: GameSnapshot[]
  relationTags   String?  // JSON: string[]
  cumulativeMood String?  // JSON: string[]

  updatedAt      DateTime @updatedAt
}

// V4 新增：结果页留言与投票
model GameReaction {
  id            String   @id @default(cuid())
  roomId        String
  participantId String
  userId        String?

  accuracyVote  String?  // "accurate" | "close" | "miss"
  comment       String?  @db.VarChar(100)

  createdAt     DateTime @default(now())

  room          Room        @relation(fields: [roomId], references: [id])
  participant   Participant @relation(fields: [participantId], references: [id])
}
